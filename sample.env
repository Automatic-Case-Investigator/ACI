# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=*

# Model provider (OpenAI-compatible — vllm or Ollama)
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=ollama
LLM_MODEL_NAME=llama3.2
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
LLM_TIMEOUT=0

# AVFS (shared workspace/memory — run via `docker compose up -d avfs`)
# Set AVFS_AUTH_TOKEN to a real value (NOT the literal below) to enable AVFS;
# docker-compose.yml reads these same values when starting the container.
AVFS_URL=http://127.0.0.1:8765/
AVFS_AUTH_TOKEN=change-me-avfs-token
AVFS_AGENT_ID=agent_1

# Wazuh (used by aci-wazuh MCP server)
# Use WAZUH_URL for the full base URL (preferred), or WAZUH_HOST alone as fallback.
WAZUH_URL=https://host.docker.internal:9200
WAZUH_USER=admin
WAZUH_PASSWORD=change-me
WAZUH_VERIFY_TLS=false
WAZUH_INDEX_PATTERN=wazuh-alerts-*

# TheHive (used by aci-thehive MCP server)
THEHIVE_HOST=http://127.0.0.1
THEHIVE_PORT=9000
THEHIVE_API_KEY=change-me-thehive-api-key
THEHIVE_VERIFY_TLS=true

# Task queue (used by aci-taskqueue MCP server)
TASKQUEUE_DB_PATH=taskqueue.db
