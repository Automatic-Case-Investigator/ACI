# Django
SECRET_KEY=change-me-in-production
DEBUG=true
ALLOWED_HOSTS=*

# Model provider (OpenAI-compatible — vllm or Ollama) is configured in the
# dashboard: Settings → Model provider (stored in the database, not here).
# Comma-separated agents that emit an extra LLM-generated public progress note
# before every action. Use "triage,investigation" or "all" for full visibility.
PUBLIC_INTENT_AGENTS=triage

# AVFS (shared workspace/memory — run via `docker compose up -d avfs`)
# Set AVFS_AUTH_TOKEN to a real value (NOT the literal below) to enable AVFS;
# docker-compose.yml reads these same values when starting the container.
AVFS_URL=http://127.0.0.1:8765/
AVFS_AUTH_TOKEN=change-me-avfs-token
AVFS_AGENT_ID=agent_1

# Automatic workflows — global kill-switch for webhook-triggered agent runs.
# When false (default), configured webhook endpoints accept the route but return
# 503 instead of dispatching. Set to true to let SIEM/SOAR webhooks start runs.
WORKFLOWS_ENABLED=false
